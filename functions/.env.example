# Used ONLY by the local Firebase emulator (npm run serve).
# Production secrets live in Google Secret Manager, set via:
#   firebase functions:secrets:set RESEND_API_KEY
#
# Copy this file to functions/.env and fill in your dev Resend key
# (or the production one if you don't mind the small risk).
# functions/.env is gitignored.

RESEND_API_KEY=re_replace_me_with_a_real_key
